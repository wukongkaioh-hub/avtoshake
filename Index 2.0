    </div>
    <div class="stat-card">
      <div class="stat-card-num">4.9\u2605</div>
      <div class="stat-card-label">Rating</div>
    </div>
    <div class="stat-card">
      <div class="stat-card-num">342</div>
      <div class="stat-card-label">Total Jobs</div>
    </div>
  </div>

  <div class="orders-section">
    <div class="orders-title">Live Orders</div>

    <div class="order-item">
      <div class="order-left">
        <div class="order-customer">Rahul Sharma \u2014 Honda City</div>
        <div class="order-service">AC Repair + Oil Change \u00b7 10:30 AM</div>
      </div>
      <div class="order-status status-active">IN PROGRESS</div>
      <div class="order-amount">\u20b9998</div>
    </div>

    <div class="order-item">
      <div class="order-left">
        <div class="order-customer">Priya Mehta \u2014 Maruti Swift</div>
        <div class="order-service">Full Service \u00b7 12:00 PM</div>
      </div>
      <div class="order-status status-pending">UPCOMING</div>
      <div class="order-amount">\u20b91,499</div>
    </div>

    <div class="order-item">
      <div class="order-left">
        <div class="order-customer">Amit Das \u2014 Hyundai i20</div>
        <div class="order-service">Tyre Change \u00b7 9:00 AM</div>
      </div>
      <div class="order-status status-done">COMPLETED</div>
      <div class="order-amount">\u20b9650</div>
    </div>

    <div class="order-item">
      <div class="order-left">
        <div class="order-customer">Sonal Roy \u2014 Tata Nexon EV</div>
        <div class="order-service">Battery Diagnostics \u00b7 2:00 PM</div>
      </div>
      <div class="order-status status-pending">UPCOMING</div>
      <div class="order-amount">\u20b91,200</div>
    </div>

    <div style="margin-top:20px;">
      <div class="orders-title">Register Your Garage</div>
      <div class="register-section" style="padding:0; margin:0;">
        <div class="step-indicator">
          <div class="step-dot done">\u2713</div>
          <div class="step-line"></div>
          <div class="step-dot active">2</div>
          <div class="step-line"></div>
          <div class="step-dot">3</div>
        </div>
        <div class="form-group">
          <label class="form-label">Garage Name</label>
          <input type="text" class="form-input" placeholder="Your garage name">
  </div>
